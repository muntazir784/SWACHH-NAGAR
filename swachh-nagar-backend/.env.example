NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000
# Production: exact frontend origin(s). Use CLIENT_URL for one site, or comma-separated CLIENT_URLS for previews + prod.
# CLIENT_URL=https://your-app.vercel.app
# CLIENT_URLS=https://your-app.vercel.app,https://deploy-preview-123.vercel.app

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
# Optional: set to true in development only if Atlas TLS fails behind strict networks (not for production)
# MONGODB_TLS_INSECURE=true
# If Atlas still fails TLS in production (SSL alert 80), set to false to disable OCSP stapling checks (weaker TLS)
# MONGODB_REQUEST_OCSP=false

# JWT
JWT_ACCESS_SECRET=<min-32-char-random-secret>
JWT_REFRESH_SECRET=<min-32-char-random-secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Admin registration invite code
ADMIN_INVITE_CODE=<your-secret-invite-code>

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=<gmail-app-password>
EMAIL_FROM=you@gmail.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# App config
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
MAX_IMAGE_SIZE_MB=5
AI_CONFIDENCE_THRESHOLD=0.65
